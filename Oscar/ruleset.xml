<?xml version="1.0"?>
<ruleset name="Oscar">
    <description>Coding standard for the Oscar technical team aligned with PER Coding Style 3.0.</description>

    <rule ref="PSR12">
        <exclude name="Squiz.WhiteSpace.ScopeClosingBrace.ContentBefore"/>
        <!-- Delegated brace errors use this code even for single-line declarations; Oscar.Functions.OpeningFunctionBraceBsdAllman restores checks with a PER §4.4 exception. -->
        <exclude name="Squiz.Functions.MultiLineFunctionDeclaration.BraceOnSameLine"/>
    </rule>

    <!-- Migration files typically omit namespaces -->
    <rule ref="PSR1.Classes.ClassDeclaration.MissingNamespace">
        <include-pattern>*/app/*</include-pattern>
    </rule>

    <config name="tab_width" value="4"/>

    <!-- Don't flag comment-only lines (e.g. long docblock lines) for line length -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="ignoreComments" value="true"/>
        </properties>
        <!-- Blade is mostly HTML/directives; long lines are normal. -->
        <exclude-pattern>*.blade.php</exclude-pattern>
        <exclude-pattern>*/resources/lang/*</exclude-pattern>
    </rule>

    <rule ref="Oscar.Namespaces.UseGrouping"/>
    <rule ref="Oscar.Attributes.AttributePlacement"/>
    <rule ref="Oscar.Closures.ShortClosure"/>
    <rule ref="Oscar.Functions.EmptyBody"/>
    <rule ref="Oscar.Functions.OpeningFunctionBraceBsdAllman"/>
    <rule ref="Oscar.Formatting.TrailingComma"/>
    <rule ref="Oscar.Blade.EmbeddedPhp" phpcs-only="true"/>
    <rule ref="Oscar.Blade.EchoSpacing"/>
    <rule ref="Oscar.Blade.JsonDirective"/>

    <!-- Blade views are mostly HTML; the PHP tokenizer reports no PHP until <?php — suppress false positive -->
    <rule ref="Internal.NoCodeFound">
        <exclude-pattern>*.blade.php</exclude-pattern>
    </rule>
</ruleset>
